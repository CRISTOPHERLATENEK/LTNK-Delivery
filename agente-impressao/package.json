{
  "name": "delivery-agente-impressao",
  "version": "1.2.0",
  "description": "Agente local de impressão térmica (ESC/POS) do Delivery — janela + bandeja (Electron).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "servidor": "node agente.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "br.com.ltnk.agenteimpressao",
    "productName": "LTNK",
    "asar": true,
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "agente.js",
      "escpos.js",
      "icone.ico",
      "lib/**/*",
      "paginas/**/*",
      "imprimir-raw.ps1",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icone.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "AgenteImpressao-Instalador.exe",
      "shortcutName": "LTNK"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
