{
  "name": "delivery-multilojas",
  "version": "1.0.0",
  "description": "Sistema de delivery multi-lojas (estilo iFood) - backend Node.js/Express + MySQL, frontend mobile-first sem build",
  "main": "dist/backend/server.js",
  "scripts": {
    "postinstall": "npm --prefix frontend install",
    "build": "tsc -p tsconfig.backend.json && cd frontend && npm run build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:react": "cd frontend && npm run build",
    "dev:react": "cd frontend && npm run dev",
    "dev:backend": "tsc -p tsconfig.backend.json --watch",
    "dev:server": "node --watch dist/backend/server.js",
    "start": "npm run build && node dist/backend/server.js",
    "start:rapido": "node dist/backend/server.js",
    "seed": "npm run build:backend && node dist/backend/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "delivery",
    "ifood",
    "multilojas"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@sentry/node": "^10.64.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.23.0",
    "node-forge": "^1.4.0",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "typescript": "^6.0.3",
    "web-push": "^3.6.7",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
