# Copie este arquivo para .env e ajuste os valores.

# Porta do servidor HTTP
PORT=3000

# ATENÇÃO: troque este segredo em produção! Use uma string longa e aleatória.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-em-producao

# Validade do token JWT (ex.: 12h, 7d)
JWT_EXPIRACAO=12h

# Chave-mestra dos SEGREDOS em repouso (senha do certificado A1, CSC da NFC-e,
# token do Mercado Pago). DEDICADA — não reutilize o JWT_SECRET.
# OBRIGATÓRIA em produção (NODE_ENV=production). Em dev cai no JWT_SECRET com aviso.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ⚠️ Trocar esta chave torna ilegíveis os segredos já salvos (re-cadastre-os).
APP_SECRET=

# Caminho do arquivo do banco SQLite (tenant padrão / master) — LEGADO, só
# usado pelo script migrar-para-mysql.ts (lê o .db antigo) e pelo db.ts
# original, mantidos até a Etapa 7 (limpeza) do plano de migração terminar.
DB_ARQUIVO=./dados/delivery.db

# ===== MySQL (persistência real — ver C:\Users\User\.claude\plans\moonlit-jumping-yeti.md) =====
# Produção deve rodar num MySQL/MariaDB com disco persistente de verdade
# (o VPS, não o "Web App Node.js" gerenciado da Hostinger, que reseta o disco
# a cada deploy). MYSQL_DATABASE = banco do tenant padrão (master).
# MYSQL_DATABASE_CENTRAL = banco do registro central de tenants (pode ser o
# mesmo que MYSQL_DATABASE em setups de tenant único). MYSQL_TENANT_PREFIX
# (opcional) prefixa o nome do banco derivado do slug ao criar um tenant novo
# pelo admin (ver dbNomeDoTenant em rotas/admin.ts) — o banco precisa ser
# CRIADO MANUALMENTE no painel do MySQL antes (o usuário não tem privilégio
# CREATE DATABASE).
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_DATABASE_CENTRAL=
MYSQL_TENANT_PREFIX=

# Multi-tenant: domínio base p/ subdomínio coringa (ex.: cliente.seuapp.com).
# Requer DNS *.seuapp.com apontando para o servidor. Vazio = só domínio próprio.
DOMINIO_BASE=

# ===== Fase 2: Mercado Pago (deixar em branco enquanto não integrado) =====
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ===== Fase 2: WhatsApp Cloud API (deixar em branco enquanto não integrado) =====
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ===== Web Push (notificações no celular, mesmo com o app fechado) =====
# Gere um par de chaves com:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Se ficar em branco, o push é desativado silenciosamente.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@exemplo.com

# ===== E-mail (recuperação de senha) =====
# Qualquer SMTP: Gmail, Hostinger, Brevo, SES... Se ficar em branco, o
# "Esqueci minha senha" continua funcionando mas não envia o e-mail de fato.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=

# ===== Monitoramento de erro (Sentry, opcional) =====
# Crie uma conta grátis em https://sentry.io, um projeto Node e outro React,
# e cole os DSN de cada um abaixo. Sem isso, o app funciona normalmente —
# só não reporta erros de produção automaticamente.
SENTRY_DSN=
VITE_SENTRY_DSN=
